page {
  background-color: #ffffff;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  box-sizing: border-box;
}

.content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-section {
  margin-bottom: 60rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
}

.title-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666666;
}

.login-section {
  width: 100%;
  margin-bottom: 60rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background-color: #4CA3FB;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn:active {
  opacity: 0.8;
}

.btn-text {
  font-size: 32rpx;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.agreement-section {
  display: flex;
  align-items: flex-start;
  width: 100%;
  padding: 0 20rpx;
}

.checkbox {
  padding: 10rpx;
  margin-right: 16rpx;
}

.checkbox-inner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #999999;
  background-color: #ffffff;
  transition: all 0.2s;
}

.checkbox-inner.checked {
  background-color: #4CA3FB;
  border-color: #4CA3FB;
  position: relative;
}

.checkbox-inner.checked::after {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 6rpx;
  width: 8rpx;
  height: 14rpx;
  border: solid #ffffff;
  border-width: 0 3rpx 3rpx 0;
  transform: rotate(45deg);
}

.agreement-text {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  padding-top: 10rpx;
}

.text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

.link {
  font-size: 24rpx;
  color: #4CA3FB;
  line-height: 1.5;
}
