/* pages/my/address/index.wxss */
/* 页面容器 */
.address-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  position: relative;
  padding: 20rpx 20rpx 120rpx;
  box-sizing: border-box;
}

/* 导航栏 */
.nav-bar {
  background-color: #fff;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #eee;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-title {
  font-size: 36rpx;
  color: #333;
  font-weight: 500;
}

.address-sync-panel {
  margin-top: 88rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.wechat-address-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background-color: #ff6b6b;
  color: #fff;
  font-size: 30rpx;
}

.wechat-address-btn::after {
  border: none;
}

.wechat-address-btn[disabled] {
  background-color: #f1a2a2;
  color: #fff;
}

.wechat-address-tip {
  display: block;
  margin-top: 16rpx;
  color: #999;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: center;
}

/* 地址列表 */
.address-list {
  padding-top: 20rpx;
}

.address-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.address-item.default {
  border: 2rpx solid #ff6b6b;
}

.address-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.address-name {
  font-size: 32rpx;
  color: #333;
}

.address-phone {
  margin-left: 40rpx;
  font-size: 30rpx;
  color: #666;
}

.default-tag {
  background-color: #ff6b6b;
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.address-detail {
  font-size: 30rpx;
  color: #666;
  line-height: 44rpx;
  margin-bottom: 20rpx;
}

.address-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.address-edit,
.address-delete,
.address-set-default {
  font-size: 28rpx;
  color: #666;
  margin-left: 40rpx;
}

.address-delete {
  color: #ff6b6b;
}

.address-set-default {
  color: #ff6b6b;
}

/* 无地址提示 */
.no-address {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
}

.no-address image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
}

.no-address-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.add-address-btn {
  background-color: #ff6b6b;
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
}

.empty-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
}

.sync-address-link {
  color: #ff6b6b;
  font-size: 30rpx;
}

/* 固定添加按钮 */
.add-address-fixed {
  position: fixed;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #ff6b6b;
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.3);
}

.add-address-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  font-weight: bold;
}
