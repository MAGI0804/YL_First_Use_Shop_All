/* pages/my/message/index.wxss */
.message-container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面头部 */
.page-header {
  background-color: #fff;
  padding: 16rpx;
  border-bottom: 1rpx solid #e5e5e5;
  position: sticky;
  top: 0;
  z-index: 10;
}

.page-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  display: block;
}

/* 消息列表 */
.message-list {
  padding: 0;
}

/* 消息项 */
.message-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 24rpx;
  margin-bottom: 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s;
}

.message-item.unread {
  border-left: 4rpx solid #C1E4FD;
}

/* 消息图标 */
.message-icon {
  width: 64rpx;
  height: 64rpx;
  background-color: #f0f9ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  color: #333;
}

/* 消息内容 */
.message-content {
  flex: 1;
  min-width: 0;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.message-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.message-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-top: 8rpx;
}

/* 未读标记 */
.unread-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #C1E4FD;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.empty-image {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 联系客服按钮 */
.customer-service-section {
  padding: 0;
}

.customer-service-btn {
  width: 100%;
  height: 90rpx;
  background-color: #C1E4FD;
  color: #333;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  outline: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: background-color 0.3s;
}

.customer-service-btn:hover {
  background-color: #A8D1F7;
}

.customer-service-btn .btn-icon {
  font-size: 36rpx;
}

.customer-service-btn .btn-text {
  font-size: 32rpx;
}