.reviews-page {
  min-height: 100vh;
  padding: 20rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}

.empty-state {
  margin-top: 180rpx;
  text-align: center;
  color: #999;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.review-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.review-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.review-product {
  color: #333;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.review-order {
  margin-top: 6rpx;
  color: #999;
  font-size: 22rpx;
}

.status {
  flex: 0 0 auto;
  padding: 6rpx 16rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  color: #666;
  background: #f2f3f5;
}

.status-pending {
  color: #d48806;
  background: #fff7e6;
}

.status-approved {
  color: #389e0d;
  background: #f6ffed;
}

.status-rejected {
  color: #cf1322;
  background: #fff1f0;
}

.review-rating {
  margin-top: 18rpx;
  color: #f6b73c;
  font-size: 28rpx;
  letter-spacing: 2rpx;
}

.review-content {
  margin-top: 14rpx;
  color: #333;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}

.review-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.review-tag {
  padding: 6rpx 16rpx;
  border-radius: 18rpx;
  color: #e64340;
  background: #fff5f5;
  font-size: 22rpx;
}

.review-footer {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eee;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: #999;
  font-size: 22rpx;
}

.actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  margin: 0;
  padding: 0 20rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 26rpx;
  background: #f5f5f5;
  color: #333;
  font-size: 24rpx;
}

.action-btn.danger {
  color: #e64340;
}

.action-btn::after {
  border: none;
}

.loading-text {
  padding: 30rpx 0;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}
