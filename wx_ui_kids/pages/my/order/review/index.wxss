.review-page {
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 140rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}

.product-card,
.form-section {
  background: #fff;
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.product-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.5;
}

.product-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #888;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.rating-row {
  display: flex;
  gap: 18rpx;
}

.star {
  font-size: 52rpx;
  color: #ddd;
  line-height: 1;
}

.star.active {
  color: #f6b73c;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid #ddd;
  color: #666;
  font-size: 24rpx;
  background: #fff;
}

.tag-item.selected {
  color: #e64340;
  border-color: #e64340;
  background: #fff5f5;
}

.content-input {
  width: 100%;
  min-height: 220rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #f7f7f7;
  color: #333;
  font-size: 26rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.content-count {
  margin-top: 12rpx;
  text-align: right;
  color: #999;
  font-size: 22rpx;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  box-sizing: border-box;
}

.submit-button {
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 41rpx;
  background: #e64340;
  color: #fff;
  font-size: 28rpx;
}

button::after {
  border: none;
}
