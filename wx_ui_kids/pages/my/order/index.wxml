<!--pages/my/order/index.wxml-->
<view class="order-container">
  <!-- 搜索框 -->
  <view class="search-container">
    <view class="search-box">
      <icon type="search" size="14" class="search-icon"></icon>
      <input 
        class="search-input" 
        placeholder="搜索商品名称" 
        placeholder-class="search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <text 
        class="search-clear" 
        wx:if="{{searchKeyword}}"
        bindtap="clearSearch"
      >✕</text>
      <view class="search-btn" bindtap="onSearchConfirm">搜索</view>
    </view>
  </view>

  <!-- 顶部状态标签栏 -->
  <scroll-view class="status-tabs" scroll-x enable-flex>
    <view
      wx:for="{{statusList}}"
      wx:key="key"
      class="status-tab {{currentStatus === item.key ? 'active' : ''}}"
      data-status="{{item.key}}"
      bindtap="switchStatus"
    >
      <text class="status-text">{{item.name}}</text>
      <view class="status-indicator {{currentStatus === item.key ? 'active' : ''}}"></view>
    </view>
  </scroll-view>

  <!-- 订单列表 -->
  <view class="order-list">
    <block wx:if="{{orderList.length > 0}}">
      <!-- 订单项 -->
      <view class="order-item" wx:for="{{orderList}}" wx:key="id" data-id="{{item.id}}" data-status="{{item.status}}" data-process-num="{{item.process_num}}" bindtap="viewOrderDetail">
        <!-- 订单头部信息 -->
        <view class="order-header">
            <view class="order-info">
              <text class="order-number">订单号：{{item.id}}</text>
              <text class="order-time">{{item.createTime}}</text>
            </view>
            <text class="order-status">{{item.statusText}}</text>
          </view>

        <!-- 订单商品列表 -->
        <view class="order-products">
          <view class="product-item" wx:for="{{item.products}}" wx:for-item="product" wx:key="id" wx:for-index="productIndex">
            <image class="product-image" src="{{product.image}}" mode="aspectFit"></image>
            <view class="product-info">
              <text class="product-name">{{product.name}}</text>
              <view class="product-price-quantity">
                <text class="product-price">¥{{product.price}}</text>
                <text class="product-quantity">x{{product.quantity}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 订单底部信息 -->
        <view class="order-footer">
          <view class="order-total">
            <text>共{{item.productCount}}件商品 合计：</text>
            <text class="total-price">¥{{item.totalPrice}}</text>
          </view>
          <!-- 订单操作按钮 -->
          <view class="order-actions">
            <!-- 待处理状态显示联系客服和取消订单 -->
            <block wx:if="{{item.status === 'pending'}}">
              <button class="action-button secondary" catchtap="contactService">联系客服</button>
              <button class="action-button primary" catchtap="cancelOrder" data-id="{{item.id}}">取消订单</button>
            </block>
            <block wx:elif="{{item.status === 'delivered' || item.status === 'shipped' }}">
              <button class="action-button secondary" catchtap="contactService">联系客服</button>
              <button class="action-button primary" catchtap="navigateToAfterSales" data-id="{{item.id}}" data-status="{{item.status}}">申请售后</button>
            </block>
            
            <!-- 其他状态显示联系客服 -->
            <block wx:else>
              <button class="action-button secondary" catchtap="contactService">联系客服</button>
            </block>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:else>
      <image src="/images/products.png" class="empty-image" mode="aspectFit"></image>
      <text class="empty-text">暂无相关订单</text>
      <button class="empty-button" bindtap="navigateToHome">去购物</button>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="load-more" wx:elif="{{!hasMore && orderList.length > 0}}">
      <text>没有更多数据了</text>
    </view>
  </view>
</view>