/* pages/my/order/detail/index.wxss */
/* 订单详情页面容器 */
.order-detail-container {
  width: 100%;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.nav-bar {
  width: 100%;
  height: 90rpx;
  background-color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: fixed;
  top: 0;
  left: 0;
  z-index: 999;
}

.nav-back {
  width: 60rpx;
  height: 100%;
  display: flex;
  align-items: center;
}

.nav-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.nav-right {
  width: 60rpx;
}

/* 订单状态区域 */
.order-status-section {
  margin-top: 0;
  width: 100%;
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.order-status-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-status-text {
  font-size: 32rpx;
  color: #e64340;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.order-status-desc {
  font-size: 26rpx;
  color: #666;
}

/* 收货地址区域 */
.address-section {
  width: 100%;
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.address-info {
  display: flex;
  flex-direction: column;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 28rpx;
  color: #333;
  margin-right: 30rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 40rpx;
}

/* 商品信息区域 */
.product-section {
  width: 100%;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-list {
  padding: 20rpx 30rpx;
}

.product-item {
  display: flex;
  margin-bottom: 20rpx;
}

.product-item:last-child {
  margin-bottom: 0;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 10rpx;
  background-color: #f5f5f5;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-price-quantity {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 30rpx;
  color: #e64340;
  font-weight: bold;
}

.product-quantity {
  font-size: 26rpx;
  color: #999;
}

/* 商品款式码和分类信息 */
.product-style,
.product-category {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 商品小计 */
.product-subtotal {
  font-size: 28rpx;
  color: #e64340;
  font-weight: bold;
}

/* 物流信息区域 */
.logistics-section {
  width: 100%;
  background-color: #fff;
  margin-bottom: 20rpx;
  cursor: pointer;
}

.logistics-section:active {
  background-color: #f5f5f5;
}

.logistics-info {
  padding: 20rpx 30rpx;
}

.logistics-company {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.logistics-company text {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.logistics-company text:last-child {
  margin-bottom: 0;
}

.logistics-status {
  padding: 10rpx 0;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  color: #1989fa;
  font-size: 26rpx;
}

/* 物流信息入口图标 */
.logistics-status::after {
  content: '>';
  margin-left: 10rpx;
  font-size: 24rpx;
  color: #ccc;
}

/* 订单信息区域 */
.order-info-section {
  width: 100%;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.info-list {
  padding: 0 30rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  text-align: right;
}

/* 价格信息区域 */
.price-section {
  width: 100%;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.price-list {
  padding: 0 30rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.price-item:last-child {
  border-bottom: none;
}

.price-item.total {
  padding: 30rpx 0;
}

.price-label {
  font-size: 26rpx;
  color: #666;
}

.price-value {
  font-size: 26rpx;
  color: #333;
  text-align: right;
  max-width: 420rpx;
}

.price-value.discount {
  color: #ff6700;
}

.price-value.total-price {
  font-size: 32rpx;
  color: #e64340;
  font-weight: bold;
}

.price-final {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.payment-note {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999;
}

/* 操作按钮区域 */
.action-buttons {
  width: 100%;
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 120rpx;
  box-sizing: border-box;
}

.action-group {
  display: flex;
  justify-content: center;
  gap: 15rpx;
  width: 100%;
  box-sizing: border-box;
}

.action-button {
  width: 130rpx;
  height: 65rpx;
  line-height: 65rpx;
  font-size: 22rpx;
  margin-left: 0;
  padding: 0;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.action-button.primary {
  background-color: #e64340;
  color: #fff;
  border: none;
}

.action-button.secondary {
  background-color: #fff;
  color: #666;
  border: 1rpx solid #ddd;
}

/* 加载状态 */
.loading-state {
  width: 100%;
  height: 200rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  color: #999;
}

/* 错误状态 */
.error-state {
  width: 100%;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  color: #999;
}

.retry-button {
  margin-top: 20rpx;
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  background-color: #e64340;
  color: #fff;
  border: none;
  border-radius: 40rpx;
}

/* 按钮统一样式覆盖 */
button {
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 确保按钮样式正确 */
button::after {
  border: none;
  border-radius: 35rpx;
  box-sizing: border-box;
}

/* 页面背景 */
page {
  background-color: #f5f5f5;
}
