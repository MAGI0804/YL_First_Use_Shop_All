<!--pages/my/order/logistics/index.wxml-->
<view class="logistics-container">
  <!-- 顶部导航栏 -->
  <!-- <view class="nav-bar">
    <view class="nav-back" bindtap="navigateBack">
      <text>返回</text>
    </view>
    <view class="nav-title">物流详情</view>
    <view class="nav-right"></view>
  </view> -->

  <!-- 物流信息 -->
  <view class="logistics-section" wx:if="{{!loading && logisticsInfo}}">
    <!-- 快递公司和运单号 -->
    <view class="logistics-header">
      <view class="logistics-company-info">
        <text class="company-label">快递公司：</text>
        <text class="company-name">{{logisticsInfo.expressCompany}}</text>
      </view>
      <view class="logistics-number-info">
        <text class="number-label">运单号：</text>
        <text class="number-value">{{logisticsInfo.expressNumber}}</text>
      </view>
    </view>

    <!-- 物流进程列表 -->
    <view class="logistics-process-section" wx:if="{{logisticsInfo.logisticsProcess && logisticsInfo.logisticsProcess.length > 0}}">
      <view class="process-title">物流进程</view>
      <view class="process-list">
        <view class="process-item" wx:for="{{logisticsInfo.logisticsProcess}}" wx:key="index">
          <!-- 连接线 -->
          <view class="process-line" wx:if="{{index > 0}}"></view>
          
          <!-- 时间和位置 -->
          <view class="process-time-location">
            <text class="process-time">{{item.time}}</text>
            <text class="process-location" wx:if="{{item.location}}">{{item.location}}</text>
          </view>
          
          <!-- 描述 -->
          <view class="process-description">
            <text>{{item.description}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 无物流进程 -->
    <view class="no-process-section" wx:elif="{{!logisticsInfo.logisticsProcess || logisticsInfo.logisticsProcess.length === 0}}">
      <text class="no-process-text">暂无物流进程信息</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载物流信息中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:if="{{!loading && errorMessage}}">
    <text class="error-text">{{errorMessage}}</text>
    <button class="retry-button" bindtap="retryRequest">重试</button>
  </view>
</view>