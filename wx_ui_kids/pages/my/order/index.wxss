/* pages/my/order/index.wxss */
/* 订单页面容器 */
.order-container {
  width: 100%;
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* 搜索容器 */
.search-container {
  padding: 16rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}
/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background-color: #fff;
  height: 70rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e6e6e6;
}

.search-icon {
  color: #999;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  height: 70rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.search-placeholder {
  color: #999;
  font-size: 28rpx;
}

.search-clear {
  font-size: 24rpx;
  color: #999;
  margin: 0 10rpx;
  padding: 4rpx 8rpx;
}

.search-btn {
  font-size: 28rpx;
  color: #1989fa;
  margin-left: 20rpx;
  box-sizing: border-box;
}

/* 顶部状态标签栏 */
.status-tabs {
  width: 100%;
  height: 90rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #e6e6e6;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}



.status-tab {
  padding: 0 20rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  box-sizing: border-box;
}

.status-text {
  font-size: 26rpx;
  color: #333;
  white-space: nowrap;
}

.status-tab.active .status-text {
  color: #e64340;
  font-weight: bold;
}

.status-indicator {
  width: 40rpx;
  height: 4rpx;
  background-color: transparent;
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
}

.status-indicator.active {
  background-color: #e64340;
}

/* 订单列表 */
.order-list {
  flex: 1;
  padding: 0;
  box-sizing: border-box;
}

/* 订单项 */
.order-item {
  width: 100%;
  max-width: 100%;
  background-color: #fff;
  padding: 20rpx;
  margin: 0;
  border-top: 1rpx solid #e6e6e6;
  border-bottom: 1rpx solid #e6e6e6;
  overflow: hidden;
  box-sizing: border-box;
}

/* 订单头部信息 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.order-info {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.order-number {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  box-sizing: border-box;
}

.order-time {
  font-size: 24rpx;
  color: #999;
  box-sizing: border-box;
}

.order-status {
  font-size: 28rpx;
  color: #e64340;
  box-sizing: border-box;
}

.status-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
}

.pay-status {
  font-size: 22rpx;
  color: #999;
}

/* 订单商品列表 */
.order-products {
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 20rpx 0;
  overflow: hidden;
  box-sizing: border-box;
}

.product-item {
  display: flex;
  margin-bottom: 16rpx;
  width: 100%;
  overflow: hidden;
  box-sizing: border-box;
}

.product-item:last-child {
  margin-bottom: 0;
}

.product-image {
  width: 100rpx;
  height: 100rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
  box-sizing: border-box;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
  min-width: 0;
  box-sizing: border-box;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  box-sizing: border-box;
}

.product-price-quantity {
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.product-price {
  font-size: 28rpx;
  color: #e64340;
  font-weight: bold;
  box-sizing: border-box;
}

.product-quantity {
  font-size: 24rpx;
  color: #999;
  box-sizing: border-box;
}

/* 订单底部信息 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-top: 20rpx;
  box-sizing: border-box;
}

.order-total {
  font-size: 26rpx;
  color: #666;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  max-width: 500rpx;
}

.total-price {
  font-size: 28rpx;
  color: #e64340;
  font-weight: bold;
  margin-left: 8rpx;
  box-sizing: border-box;
}

.settlement-text {
  width: 100%;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999;
}

.order-actions {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.action-button {
  width: 96rpx;
  height: 48rpx;
  line-height: 48rpx;
  font-size: 22rpx;
  margin-top: 8rpx;
  margin-left: 0;
  padding: 0;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.action-button:first-child {
  margin-top: 0;
}

.action-button.primary {
  background-color: #e64340;
  color: #fff;
  border: none;
}

.action-button.secondary {
  background-color: #fff;
  color: #666;
  border: 1rpx solid #ddd;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  box-sizing: border-box;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
  box-sizing: border-box;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.empty-button {
  width: 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  background-color: #e64340;
  color: #fff;
  border: none;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #999;
  box-sizing: border-box;
}

/* 下拉刷新样式 */
page {
  background-color: #f5f5f5;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  width: 100%;
  height: 100%;
}

/* 按钮统一样式覆盖 */
button {
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 确保按钮样式正确 */
button::after {
  border: none;
  border-radius: 0;
  box-sizing: border-box;
}
