/* pages/my/message_details/index.wxss */

/* 页面容器 */
.message-details-container {
  width: 100%;
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 消息项 */
.message-item {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-left: 4rpx solid #C1E4FD;
  box-sizing: border-box;
}

/* 消息头部 */
.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  box-sizing: border-box;
}

/* 消息标题 */
.message-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  box-sizing: border-box;
}

/* 消息时间 */
.message-time {
  font-size: 24rpx;
  color: #999;
  box-sizing: border-box;
}

/* 消息副标题 */
.message-subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

/* 消息内容 */
.message-content {
  font-size: 26rpx;
  color: #666;
  line-height: 40rpx;
  white-space: pre-wrap;
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  box-sizing: border-box;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  box-sizing: border-box;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 30rpx 0;
  box-sizing: border-box;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  box-sizing: border-box;
}

/* 没有更多数据 */
.no-more-state {
  text-align: center;
  padding: 30rpx 0;
  box-sizing: border-box;
}

.no-more-text {
  font-size: 26rpx;
  color: #999;
  box-sizing: border-box;
}

/* 联系客服按钮区域 */
.customer-service-section {
  padding: 0;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  box-sizing: border-box;
}

/* 联系客服按钮 */
.customer-service-btn {
  width: 100%;
  height: 90rpx;
  background-color: #C1E4FD;
  color: #333;
  border: none;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 按钮文本 */
.btn-text {
  font-size: 30rpx;
  box-sizing: border-box;
}

/* 按钮统一样式覆盖 */
button {
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 确保按钮样式正确 */
button::after {
  border: none;
  box-sizing: border-box;
}