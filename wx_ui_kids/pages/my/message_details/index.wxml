<!--pages/my/message_details/index.wxml-->
<view class="message-details-container">
  <!-- 消息列表 -->
  <view class="message-list">
    <!-- 消息项 -->
    <view class="message-item" wx:for="{{messageList}}" wx:key="id" bindtap="handleMessageTap" data-message="{{item}}">
      <!-- 消息头部 -->
      <view class="message-header">
        <text class="message-title">{{item.title}}</text>
        <text class="message-time">{{item.time}}</text>
      </view>
      
      <!-- 消息副标题 -->
      <text class="message-subtitle">{{item.subtitle}}</text>
      
      <!-- 消息内容 -->
      <view class="message-content">
        <text>{{item.content}}</text>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{messageList.length === 0 && !loading}}">
      <text class="empty-text">暂无消息</text>
    </view>
    
    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>
    
    <!-- 没有更多数据 -->
    <view class="no-more-state" wx:if="{{!loading && !hasMore && messageList.length > 0}}">
      <text class="no-more-text">没有更多消息了</text>
    </view>
  </view>

  <!-- 联系客服按钮 -->
  <view class="customer-service-section">
    <button class="customer-service-btn" bindtap="contactService">
      <text class="btn-text">联系客服</text>
    </button>
  </view>
</view>