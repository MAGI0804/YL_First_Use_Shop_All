<!--pages/search/display/index.wxml-->
<view class="search-results-container">
  <!-- 搜索关键词和结果数量 -->
  <view class="search-header">
    <text class="keyword">{{keyword}}</text>
    <text class="result-count">({{totalCount}}个结果)</text>
  </view>

  <!-- 空状态显示 -->
  <view class="empty-state" wx:if="{{isEmpty}}">
    <image class="empty-icon" src="/images/home.png" mode="aspectFit"></image>
    <text class="empty-text">暂无满足要求的商品</text>
  </view>

  <!-- 商品列表 -->
  <view class="goods-list" wx:else>
    <!-- 商品项 -->
    <block wx:for="{{goodsList}}" wx:key="style_code">
      <view class="goods-item" bindtap="navigateToDetail" data-id="{{item.style_code}}">
        <!-- 商品图片 -->
        <view class="goods-image-container">
          <image class="goods-image" src="{{item.promo_image_url || '/images/placeholder.png'}}" mode="aspectFill"></image>
        </view>
        <!-- 商品信息 -->
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-price">¥{{item.price}}</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 加载提示 -->
  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>