/* pages/commodity/goods/index.wxss */
.goods-container {
  display: flex;
  flex-direction: column;
  background-color: #fff;
  min-height: 100vh;
  position: relative;
}

/* 返回按钮样式 */
.back-btn {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

/* 加载状态样式 */
.loading-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.spinner {
  width: 50rpx;
  height: 50rpx;
  border: 6rpx solid rgba(0, 0, 0, 0.1);
  border-top-color: #333;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 32rpx;
  color: #666;
}

.error-container {
  min-height: 60vh;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.error-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 28rpx;
}

.error-btn {
  min-width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 8rpx;
  background: #1769aa;
  color: #fff;
  font-size: 28rpx;
}

.error-btn::after {
  border: none;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.back-icon {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}

/* 轮播图样式 */
.swiper-container {
  position: relative;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.9);
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-icon {
  display: inline-block;
  width: 30rpx;
  height: 30rpx;
  border-left: 2rpx solid #333;
  border-top: 2rpx solid #333;
  transform: rotate(-45deg);
}

.search-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.swiper-container {
  width: 100%;
  height: 100vw;
  overflow: hidden;
  background-color: #f5f5f5;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 0;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.indicator-overlay {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  z-index: 10;
}

/* 商品标题样式 */
.goods-title-container {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.goods-title {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-subtitle {
  font-size: 28rpx;
  color: #666;
}

/* 商品价格样式 */
.goods-price-container {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
  background-color: #fafafa;
}

.price-box {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.current-price {
  font-size: 40rpx;
  color: #e64340;
  font-weight: bold;
  margin-right: 20rpx;
}

.original-price {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
}

.discount-tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  background-color: #fff1f0;
  color: #e64340;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
  margin-bottom: 10rpx;
}

/* 模态框图片和价格容器样式 */
.modal-image-price-container {
  display: flex;
  padding: 20rpx;
  background-color: #f8f8f8;
  margin-bottom: 30rpx;
}

.modal-image-wrapper {
  display: flex;
  margin-right: 30rpx;
}

.modal-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  background-color: #fff;
}

.modal-info-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.modal-price-row {
  display: flex;
  flex-direction: column;
}

.modal-current-price {
  font-size: 40rpx;
  color: #e64340;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.modal-original-price {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
}

.modal-quantity-stock-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-stock-info {
  font-size: 24rpx;
  color: #999;
}

/* 数量选择器样式 */
.quantity-selector {
  display: flex;
  align-items: center;
}

.qty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border: 1rpx solid #ddd;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
}

.qty-value {
  padding: 8rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  border-top: 1rpx solid #ddd;
  border-bottom: 1rpx solid #ddd;
}

/* 商品信息样式 */
.goods-info-container {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.info-item {
  display: flex;
  margin-bottom: 16rpx;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 购买按钮样式 */
.buy-container {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  padding: 0 20rpx;
  box-sizing: border-box;
  z-index: 100;
  align-items: center;
}

/* 左侧图标按钮区域 */
.left-buttons {
  display: flex;
  align-items: center;
  width: auto;
  margin-right: 20rpx;
}

/* 图标按钮样式 */
.icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  width: auto;
}

/* 按钮图标样式 */
.btn-icon {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 5rpx;
}

/* 按钮文字样式 */
.btn-text {
  font-size: 18rpx;
  color: #333;
  white-space: nowrap;
}

/* 右侧大按钮区域 */
.right-buttons {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
  flex-wrap: nowrap;
  overflow: hidden;
}

/* 加入感兴趣的商品按钮样式 */
.cart-btn {
  background-color: #D6E9FC;
  color: #333;
  font-size: 32rpx;
  border-radius: 0;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  flex: 1;
  white-space: nowrap;
  padding: 0;
  margin-right: 10rpx;
  box-sizing: border-box;
}

/* 下单按钮样式 */
.buy-btn {
  background-color: #4A90E2;
  color: #fff;
  font-size: 32rpx;
  border-radius: 0;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  flex: 1;
  white-space: nowrap;
  padding: 0;
  margin-left: 10rpx;
  box-sizing: border-box;
}

/* 商品展示图片区域（纵向显示）样式 */
.display-pictures-container {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 100rpx; /* 为底部固定按钮留出空间 */
}

.display-pictures-container .section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.display-picture-item {
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
  background-color: #f8f8f8;
}

.display-picture {
  width: 100%;
  height: 700rpx;
  object-fit: cover;
  border-radius: 10rpx;
}

/* 尺码颜色选择弹出层样式 */
.select-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  animation: modalSlideUp 0.3s ease-out;
}

@keyframes modalSlideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  animation: overlayFadeIn 0.3s ease-out;
}

@keyframes overlayFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.modal-content {
  position: relative;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform-origin: bottom center;
  animation: contentSlideUp 0.3s ease-out;
}

@keyframes contentSlideUp {
  from {
    opacity: 0;
    transform: translateY(100%) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  background-color: #fff;
  z-index: 10;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
  max-height: calc(80vh - 200rpx); /* 为底部按钮留出空间 */
}

.select-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.color-options,
.size-options {
  display: flex;
  flex-wrap: wrap;
}

.size-grid {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
}

.color-item,
.size-item {
  padding: 16rpx 24rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #333;
  min-width: 100rpx;
  text-align: center;
}

.color-item,
.size-item {
  padding: 16rpx 24rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #333;
  min-width: 100rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.color-item:hover,
.size-item:hover {
  border-color: #e64340;
}

.color-item.selected,
.size-item.selected {
  border-color: #e64340;
  color: #e64340;
  background-color: #fff1f0;
  box-shadow: 0 0 0 2rpx rgba(230, 67, 64, 0.1);
}

.select-tip {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx 0;
}

/* 数量选择器样式 */
.quantity-selector {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.quantity-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #ddd;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.quantity-btn.minus {
  border-radius: 40rpx 0 0 40rpx;
}

.quantity-btn.plus {
  border-radius: 0 40rpx 40rpx 0;
}

.quantity-btn:disabled {
  color: #ccc;
  background-color: #f5f5f5;
}

.quantity-input {
  width: 120rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 1rpx solid #ddd;
  border-bottom: 1rpx solid #ddd;
  font-size: 32rpx;
  color: #333;
}

.stock-info {
  font-size: 24rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
  background-color: #fff;
  position: sticky;
  bottom: 0;
  z-index: 10;
}

.cancel-btn {
  flex: 1;
  background-color: #f5f5f5;
  color: #666;
  font-size: 32rpx;
  margin-right: 20rpx;
  border-radius: 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-btn {
  flex: 1;
  background-color: #4A90E2;
  color: #fff;
  font-size: 32rpx;
  border-radius: 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
