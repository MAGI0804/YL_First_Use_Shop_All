/* 下单页面样式 - 模仿地址页面设计风格 */
/* 页面容器 */
.order-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 导航栏 */
.nav-bar {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  border-bottom: 1rpx solid #eaeaea;
  position: relative;
  padding: 0 30rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.nav-right {
  position: absolute;
  right: 30rpx;
}

.clear-btn {
  font-size: 32rpx;
  color: #ff6700;
}

/* 通用区域标题 */
.section-title {
  font-size: 28rpx;
  color: #666666;
  padding: 30rpx 30rpx 15rpx;
  background-color: #f5f5f5;
}

/* 地址选择区域 */
.address-section {
  margin-bottom: 20rpx;
  background-color: #ffffff;
}

.address-card {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.address-content {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 30rpx;
  color: #666666;
}

.default-tag {
  margin-left: 15rpx;
  font-size: 24rpx;
  color: #ff6700;
  padding: 0 10rpx;
  border: 1rpx solid #ff6700;
  border-radius: 4rpx;
}

.address-detail {
  font-size: 30rpx;
  color: #666666;
  line-height: 40rpx;
  word-break: break-all;
}

.address-placeholder {
  width: 100%;
}

.address-empty-tip {
  font-size: 32rpx;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.address-action-tip {
  font-size: 28rpx;
  color: #999999;
  display: block;
}

.arrow-right {
  width: 24rpx;
  height: 24rpx;
}

.arrow-right image {
  width: 100%;
  height: 100%;
}

/* 商品信息区域 */
.goods-section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.goods-list {
  padding: 0 20rpx 20rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 180rpx;
  height: 180rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  margin-right: 20rpx;
  overflow: hidden;
}

.goods-image image {
  width: 100%;
  height: 100%;
}

.goods-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-title {
  font-size: 30rpx;
  color: #333333;
  line-height: 44rpx;
  word-break: break-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.goods-spec {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 15rpx;
}

.goods-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 32rpx;
  color: #ff6700;
  font-weight: 500;
}

.goods-quantity {
  font-size: 28rpx;
  color: #666666;
}

/* 价格信息区域 */
.price-section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.price-list {
  padding: 0 20rpx 20rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.price-item:last-child {
  border-bottom: none;
}

.price-label {
  font-size: 30rpx;
  color: #666666;
}

.price-value {
  font-size: 30rpx;
  color: #333333;
}

.price-value.discount {
  color: #ff6700;
}

/* 优惠券区域 */
.coupon-section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.coupon-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}

.coupon-label {
  font-size: 30rpx;
  color: #333333;
}

.coupon-value {
  display: flex;
  align-items: center;
}

.coupon-text {
  font-size: 28rpx;
  color: #999999;
  margin-right: 10rpx;
}

.coupon-value .arrow-right {
  width: 20rpx;
  height: 20rpx;
}

/* 订单备注区域 */
.remark-section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.remark-input {
  margin: 0 30rpx 30rpx;
  font-size: 28rpx;
  color: #333333;
  padding: 15rpx 0;
  line-height: 40rpx;
}

/* 服务承诺区域 */
.service-section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
  padding: 20rpx 0;
}

.service-tags {
  display: flex;
  padding: 0 30rpx;
  flex-wrap: wrap;
}

.service-tag {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
  margin-bottom: 20rpx;
}

.service-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.service-text {
  font-size: 26rpx;
  color: #999999;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.total-price {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  max-width: 420rpx;
}

.total-label {
  font-size: 28rpx;
  color: #333333;
}

.total-amount {
  font-size: 36rpx;
  color: #ff6700;
  font-weight: 600;
}

.settlement-tip {
  width: 100%;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #999999;
}

.submit-btn {
  min-width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  border-radius: 12rpx;
  background-color: #73B7FC;
  color: #FFFFFF;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
  letter-spacing: 2rpx;
}

/* 适配不同屏幕尺寸 */
@media screen and (min-width: 768rpx) {
  .order-container {
    padding-left: 20rpx;
    padding-right: 20rpx;
  }
}
