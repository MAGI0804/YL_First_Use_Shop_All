APP_ENV=development
APP_PORT=3088
LOG_DIR=./logs
# 后台跨域允许的前端 URL 列表，多个地址用英文逗号分隔
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DB_ENGINE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=wechat_member
DB_CHARSET=utf8mb4

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=1

JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_TTL_HOURS=1
JWT_REFRESH_TOKEN_TTL_HOURS=24

WECHAT_APP_ID=
WECHAT_APP_SECRET=
# 微信小程序登录接口 URL，用于 jscode2session 换取 openid/session_key
WECHAT_LOGIN_URL=https://api.weixin.qq.com/sns/jscode2session
# 微信稳定 access_token 接口，用于手机号 code 换取手机号
WECHAT_ACCESS_TOKEN_URL=https://api.weixin.qq.com/cgi-bin/stable_token
# 微信手机号换取接口
WECHAT_PHONE_NUMBER_URL=https://api.weixin.qq.com/wxa/business/getuserphonenumber

ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# 聚水潭接口环境阶段：test/develop 使用测试环境；prod/production/formal 使用正式环境
JST_ENV_STAGE=develop
JST_APP_KEY_TEST=
JST_APP_SECRET_TEST=
JST_AUTH_CODE_TEST=
JST_APP_KEY_PROD=
JST_APP_SECRET_PROD=
JST_AUTH_CODE_PROD=
JST_SHOP_ID=

# 聚水潭测试环境初始化 token URL，用于测试应用授权换取 access_token
JST_GET_TOKEN_URL_TEST=https://dev-api.jushuitan.com/openWebIsv/auth/getInitToken
# 聚水潭正式环境初始化 token URL，用于正式应用授权换取 access_token
JST_GET_TOKEN_URL_PROD=https://openapi.jushuitan.com/openWeb/auth/getInitToken
# 聚水潭测试环境 OpenAPI 基础域名，兼容旧封装使用
JST_OPEN_API_URL_TEST=https://dev-api.jushuitan.com
# 聚水潭正式环境 OpenAPI 基础域名，兼容旧封装使用
JST_OPEN_API_URL_PROD=https://openapi.jushuitan.com

# 聚水潭测试环境店铺查询 URL，用于查询自研商城绑定的聚水潭店铺
JST_SHOP_QUERY_URL_TEST=https://dev-api.jushuitan.com/open/shops/query
# 聚水潭正式环境店铺查询 URL，用于查询自研商城绑定的聚水潭店铺
JST_SHOP_QUERY_URL_PROD=https://openapi.jushuitan.com/open/shops/query
# 聚水潭测试环境订单上传 URL，用于自研商城订单推送 ERP
JST_ORDER_UPLOAD_URL_TEST=https://dev-api.jushuitan.com/open/jushuitan/orders/upload
# 聚水潭正式环境订单上传 URL，用于自研商城订单推送 ERP
JST_ORDER_UPLOAD_URL_PROD=https://openapi.jushuitan.com/open/jushuitan/orders/upload
# 聚水潭测试环境售后上传 URL，用于自研商城售后单推送 ERP
JST_AFTERSALE_UPLOAD_URL_TEST=https://dev-api.jushuitan.com/open/aftersale/upload
# 聚水潭正式环境售后上传 URL，用于自研商城售后单推送 ERP
JST_AFTERSALE_UPLOAD_URL_PROD=https://openapi.jushuitan.com/open/aftersale/upload
# 聚水潭测试环境售后实际收货查询 URL，用于查询 ERP 退货入库结果
JST_AFTERSALE_RECEIVED_QUERY_URL_TEST=https://dev-api.jushuitan.com/open/aftersale/received/query
# 聚水潭正式环境售后实际收货查询 URL，用于查询 ERP 退货入库结果
JST_AFTERSALE_RECEIVED_QUERY_URL_PROD=https://openapi.jushuitan.com/open/aftersale/received/query
# 聚水潭测试环境发货信息查询 URL，用于自研商城拉取 ERP 发货物流
JST_LOGISTIC_QUERY_URL_TEST=https://dev-api.jushuitan.com/open/logistic/query
# 聚水潭正式环境发货信息查询 URL，用于自研商城拉取 ERP 发货物流
JST_LOGISTIC_QUERY_URL_PROD=https://openapi.jushuitan.com/open/logistic/query
# 聚水潭测试环境商品库存查询 URL，用于测试环境库存校准
JST_INVENTORY_QUERY_URL_TEST=https://dev-api.jushuitan.com/open/inventory/query
# 聚水潭正式环境商品库存查询 URL，用于正式环境库存校准和同步
JST_INVENTORY_QUERY_URL_PROD=https://openapi.jushuitan.com/open/inventory/query
# 聚水潭测试环境店铺 SKU 映射查询 URL，用于测试环境商品自动化同步
JST_SKUMAP_QUERY_URL_TEST=https://dev-api.jushuitan.com/open/skumap/query
# 聚水潭正式环境店铺 SKU 映射查询 URL，用于商品自动化同步
JST_SKUMAP_QUERY_URL_PROD=https://openapi.jushuitan.com/open/skumap/query
# 聚水潭测试环境商品资料查询 URL，用于测试环境商品自动化同步
JST_SKU_QUERY_URL_TEST=https://dev-api.jushuitan.com/open/sku/query
# 聚水潭正式环境商品资料查询 URL，用于商品自动化同步
JST_SKU_QUERY_URL_PROD=https://openapi.jushuitan.com/open/sku/query
